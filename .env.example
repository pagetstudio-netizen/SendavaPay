# ============================
# Variables d'environnement SendavaPay
# Copier ce fichier en .env et remplir les valeurs
# ============================

NODE_ENV=production
PORT=5000

# Base de données PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/sendavapay

# Session
SESSION_SECRET=your-very-secret-session-key-change-this

# URL de base du site
BASE_URL=https://sendavapay.com

# SoleasPay
SOLEASPAY_API_KEY=
SOLEASPAY_SECRET_KEY=

# LeekPay
LEEKPAY_SECRET_KEY=

# Supabase (optionnel)
SUPABASE_DATABASE_URL=

# Stockage objet (optionnel - Replit Object Storage)
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=
